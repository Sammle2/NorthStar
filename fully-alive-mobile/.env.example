# ─────────────────────────────────────────────────────────────────────────────
# NorthStar — environment variables
# Copy to `.env.local` for local dev. In CI/hosting (Netlify/Vercel/EAS), set
# these in the project's environment settings.
#
# Anything prefixed EXPO_PUBLIC_ is INLINED INTO THE CLIENT BUNDLE and shipped to
# every user. Put ONLY public values here. Never put real secrets (Anthropic key,
# Supabase service_role key) in any EXPO_PUBLIC_ variable.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (public)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase publishable / anon key (public — RLS protects the data)
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS — do NOT put these in the client / .env.local.
# Set them as Supabase Edge Function secrets instead:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-... --project-ref YOUR-PROJECT-ref
#
#   ANTHROPIC_API_KEY   — used by the `claude-proxy` edge function for Coach,
#                         dream-life stories, and goal/milestone generation.
# ─────────────────────────────────────────────────────────────────────────────
